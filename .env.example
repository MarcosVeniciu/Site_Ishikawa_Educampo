# URL base da API de Diagnóstico (já hospedada e em produção)
API_BASE_URL=https://api-ishikawa-educampo.onrender.com

# Token de Autenticação da API (Substitua pelo token real)
API_TOKEN=insira-token-aqui

# Feature Flags de Segurança
# Ative (true) quando a API em Python for atualizada para suportar descriptografia AES
ENABLE_PAYLOAD_ENCRYPTION=false
ENCRYPTION_SECRET_KEY=sua_chave_simetrica_gerada_aleatoriamente